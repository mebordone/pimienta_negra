<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chat — Pimienta</title>
  <link rel="icon" href="/favicon.ico" type="image/png" />
  <link rel="stylesheet" href="vendor/converse.min.css" />
  <style>
    html, body { height: 100%; margin: 0; }
  </style>
</head>
<body class="converse-fullscreen">
  <script src="vendor/converse.min.js"></script>
  <script>
    (function () {
      var host = window.location.host;
      var wsProto = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
      var wsUrl = wsProto + '//' + host + '/xmpp-websocket';
      var boshUrl = window.location.protocol + '//' + host + '/http-bind';
      converse.initialize({
        assets_path: '/chat/vendor/',
        view_mode: 'fullscreen',
        language: 'es',
        discover_connection_methods: false,
        websocket_url: wsUrl,
        bosh_service_url: boshUrl,
        jid: '__NODE_DOMAIN__',
        muc_domain: '__XMPP_CONFERENCE_DOMAIN__',
        locked_muc_domain: '__XMPP_CONFERENCE_DOMAIN__',
        auto_join_rooms: [
          'general@__XMPP_CONFERENCE_DOMAIN__',
          'maestranza@__XMPP_CONFERENCE_DOMAIN__',
          'asamblea@__XMPP_CONFERENCE_DOMAIN__'
        ],
        play_sounds: false,
        show_controlbox_by_default: true,
        authentication: 'anonymous',
        auto_login: true,
        auto_reconnect: true
      });
    })();
  </script>
</body>
</html>
