# Ignorar TODA la carpeta data (donde viven las bases de datos y llaves)
data/

# Entorno Python local (no forma parte del stack Docker)
venv/
__pycache__/
*.pyc

# Variables locales (contraseñas FileBrowser, etc.)
.env

# Volúmenes de usuario (FileBrowser); solo versionamos .gitkeep
archivos/*
!archivos/.gitkeep

# Ignorar otros archivos basura
*.tmp
.DS_Store
*.key
