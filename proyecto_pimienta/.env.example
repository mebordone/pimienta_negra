# Copiar a `.env` en este mismo directorio si querés fijar variables sin exportarlas en la shell.

# --- Gateway y wiki (leer juntos) ---
# El puerto del nginx en el host. Por defecto en docker-compose es 80.
# Si el 80 está ocupado (muy común en desarrollo), usá otro puerto y **mismo número en MW_SERVER**:
#
#   GATEWAY_HTTP_PORT=8088
#   MW_SERVER=http://pimienta.local:8088
#
# Así MediaWiki genera enlaces y redirecciones correctas (sin quedar colgados en http://pimienta.local sin puerto).
# Con puerto 80, MW_SERVER puede ser solo http://pimienta.local (sin :80).
#
# GATEWAY_HTTP_PORT=8088
# MW_SERVER=http://pimienta.local:8088

# FileBrowser: mínimo 8 caracteres cada una.
FILEBROWSER_ADMIN_PASSWORD=cambiar_esta_clave_admin
FILEBROWSER_INVITADO_PASSWORD=cambiar_esta_clave_invitado

# Prosody — cuenta admin@accounts.pimienta.local (moderación / XMPP).
# PROSODY_ADMIN_PASSWORD=cambiar_esta_clave_prosody
